{
    "compilerOptions": {
        "baseUrl": ".",
        "paths": {
            "@/*": [
                "./src/*"
            ]
        },
        "jsx": "react-jsx",
        "module": "ESNext",
        "moduleResolution": "Bundler",
        "target": "ESNext",
        "lib": [
            "DOM",
            "DOM.Iterable",
            "ESNext"
        ],
        "skipLibCheck": true
    },
    "typeAcquisition": {
        "include": [
            "react",
            "react-dom"
        ],
        "exclude": [
            "d3-array",
            "d3-color",
            "d3-ease",
            "d3-interpolate",
            "d3-path",
            "d3-scale",
            "d3-shape",
            "d3-time",
            "d3-timer"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}